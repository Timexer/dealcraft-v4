generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Player {
  id             String   @id @default(cuid())
  name           String
  careerTier     Int      @default(1)
  casesCompleted Int      @default(0)
  totalScore     Int      @default(0)
  currentCaseId  String?
  gamePhase            String   @default("dashboard")
  completedScenarioIds String   @default("[]")
  stats                String   @default("{}")
  reputation           String   @default("{}")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  caseResults    CaseResult[]
}

model CaseResult {
  id               String   @id @default(cuid())
  playerId         String
  scenarioId       String
  outcome          String
  finalScore       Int
  choicesMade      String   @default("[]")
  advisorLogs      String   @default("[]")
  hiddenFactsFound String   @default("[]")
  postmortemRead   Boolean  @default(false)
  createdAt        DateTime @default(now())
  player           Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
}
